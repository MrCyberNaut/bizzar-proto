# 8th Wall App Key
# 1. Go to https://www.8thwall.com → sign up free
# 2. Create an app → copy the App Key
# 3. Whitelist domains: localhost, your-ngrok-url.ngrok.io
# 4. Copy this file to .env.local and fill in your key
NEXT_PUBLIC_8THWALL_KEY=

# Optional: set to your ngrok URL when testing on mobile
NEXT_PUBLIC_APP_URL=http://localhost:3000
